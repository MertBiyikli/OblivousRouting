{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "${env:HOME}/local/ortools",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "Boost_DIR": "/usr/local/lib/cmake/Boost-1.88.0",
        "BUILD_TESTS": "OFF"
      }
    },

    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-g -Wall -Wextra -pedantic -fsanitize=address"
      }
    },

    {
      "name": "release",
      "displayName": "Release (LTO)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-O3"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" }
  ],

  "testPresets": [
    {
      "name": "test-debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
